{
  "manifest_version": 3,
  "name": "Transcript Extractor",
  "description": "Turn any video into text — capture transcripts as you browse, or drop a video/audio file for local AI transcription. Free.",
  "version": "1.5.0",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "webNavigation",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.vimeo.com/*",
    "*://player.vimeo.com/*"
  ],
  "optional_host_permissions": [
    "*://huggingface.co/*",
    "*://*.huggingface.co/*",
    "*://cdn-lfs.huggingface.co/*",
    "*://cdn-lfs.hf.co/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://*.youtube.com https://*.googlevideo.com https://*.vimeo.com https://player.vimeo.com https://huggingface.co https://*.huggingface.co https://cdn-lfs.huggingface.co https://cdn-lfs.hf.co"
  },
  "action": {
    "default_title": "Transcript Extractor",
    "default_popup": "sidepanel/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/yt-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/yt-bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.youtube.com/watch*",
        "*://*.youtube.com/shorts/*",
        "*://*.youtube.com/embed/*",
        "*://*.youtube.com/live/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.vimeo.com/*"
      ],
      "js": ["content/vimeo-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
