{
  "name": "yt-transcript",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsc -b && node scripts/build.mjs",
    "build:firefox": "tsc -b && node scripts/build.mjs && node scripts/build-firefox.mjs",
    "zip": "node scripts/build.mjs && node scripts/package-stores.mjs",
    "zip:chrome": "node scripts/build.mjs && cd dist && zip -r ../yt-transcript-chrome.zip .",
    "zip:firefox": "node scripts/build.mjs && node scripts/build-firefox.mjs && cd dist-firefox && zip -r ../yt-transcript-firefox.zip .",
    "test:browser": "node scripts/test-extension.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@tanstack/react-virtual": "^3.13.6",
    "fflate": "^0.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.4.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "esbuild": "^0.27.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "web-ext": "^10.1.0"
  }
}
