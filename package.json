{
  "name": "yt-transcript",
  "private": true,
  "version": "1.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsc -b && node scripts/build.mjs",
    "zip": "node scripts/build.mjs && node scripts/package-stores.mjs",
    "zip:chrome": "node scripts/build.mjs && cd dist && zip -r ../yt-transcript-chrome.zip .",
    "test:browser": "node scripts/test-extension.mjs",
    "lint": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@tanstack/react-virtual": "^3.13.6",
    "fflate": "^0.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@tailwindcss/vite": "4.3.1",
    "@types/chrome": "0.2.0",
    "@types/node": "25.9.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "esbuild": "0.28.1",
    "react-markdown": "9.1.0",
    "remark-gfm": "4.0.1",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "web-ext": "10.4.0"
  }
}
